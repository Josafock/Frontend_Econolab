{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Econolab",
  "version": "0.1.0",
  "identifier": "com.econolab.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node scripts/tauri-dev.mjs",
    "beforeBuildCommand": "npm run build:desktop && npm run prepare:backend:runtime"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Econolab",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/backend-runtime/**/*",
      "resources/node/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
